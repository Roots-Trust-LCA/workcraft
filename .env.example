# Workshop Configuration
# Copy to .env and fill in your values

# Required: Supabase project
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Workshop identity
VITE_WORKSHOP_NAME=Workshop
VITE_WORKSHOP_DESCRIPTION=Agent Coordination Workshop
VITE_ORG_NAME=Your Organization
VITE_ORG_URL=https://your-org.example

# Protocol settings
VITE_SPRINT_ID_PREFIX=P
VITE_MAX_WIP_PER_AGENT=2
VITE_AGING_ALERT_DAYS=14
VITE_HUMAN_REVIEW_DEFAULT=true

# Auth (default: fully public)
VITE_REQUIRE_AUTH_TO_WRITE=false
